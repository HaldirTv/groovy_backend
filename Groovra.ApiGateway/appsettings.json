{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/{**catch-all}" },
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-static-files": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/files/{**catch-all}" },
        "Order": 0,
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-jamendo": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/jamendo/{**catch-all}" },
        "Order": 1,
        "AuthorizationPolicy": "AdminOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-tracks-modify": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "Order": 2,
        "AuthorizationPolicy": "ArtistOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-albums-modify": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/albums/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "Order": 2,
        "AuthorizationPolicy": "ArtistOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-favorites-route": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/favorites/{**catch-all}" },
        "Order": 2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-playlists-route": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/playlists/{**catch-all}" },
        "Order": 2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "history-route": {
        "ClusterId": "history-cluster",
        "Match": { "Path": "/api/history/{**catch-all}" },
        "Order": 2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-route": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/{**catch-all}" },
        "Order": 3,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "auth-openapi-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/docs/auth/openapi.json" },
        "Transforms": [ { "PathPattern": "/openapi/v1.json" } ]
      },
      "music-openapi-route": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/docs/music/openapi.json" },
        "Transforms": [ { "PathPattern": "/openapi/v1.json" } ]
      },
      "history-openapi-route": {
        "ClusterId": "history-cluster",
        "Match": { "Path": "/docs/history/openapi.json" },
        "Transforms": [ { "PathPattern": "/openapi/v1.json" } ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": { "Address": "http://auth-service:8080" }
        }
      },
      "music-cluster": {
        "Destinations": {
          "music-destination": { "Address": "http://music-service:8080" }
        }
      },
      "history-cluster": {
        "Destinations": {
          "history-destination": { "Address": "http://history-service:8080" }
        }
      }
    }
  },
  "Jwt": {
    "Key": "super_secret_groovra_jwt_key_that_is_long_enough_32_bytes!",
    "Issuer": "groovra.local",
    "Audience": "groovra.clients"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5178",
      "https://groovra-frontend.vercel.app"
    ]
  }
}