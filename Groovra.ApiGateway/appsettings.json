{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "music-static-files": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/files/{**catch-all}"
        },
        "Order": 0
      },
      "music-jamendo": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/jamendo/{**catch-all}"
        },
        "Order": 1,
        "AuthorizationPolicy": "AdminOnly"
      },
      "music-get-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Order": 2,
        "AuthorizationPolicy": "Default"
      },
      "profile-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/profile/{**catch-all}"
        }
      },
      "media-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/media/{**catch-all}"
        }
      },

      "music-modify-route": {
        "ClusterId": "music-cluster",
        "Order": 2,
        "Match": {
          "Path": "/music/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "AuthorizationPolicy": "ArtistOnly"
      },
      "history-route": {
        "ClusterId": "history-cluster",
        "Match": {
          "Path": "/api/history/{**catch-all}"
        },
        "Order": 2,
        "AuthorizationPolicy": "Default"
      },

      "music-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/{**catch-all}"
        },
        "Order": 3,
        "AuthorizationPolicy": "Default"
      },



      "auth-openapi-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/docs/auth/openapi.json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "music-openapi-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/docs/music/openapi.json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "history-openapi-route": {
        "ClusterId": "history-cluster",
        "Match": {
          "Path": "/docs/history/openapi.json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      }


    },
    "Clusters": {
      "auth-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "auth-destination": {

            "Address": "https://localhost:7008"
          }
        }
      },
      "music-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "music-destination": {
            "Address": "https://localhost:7176"
          }
        }
      },
      "history-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "Destinations": {
          "history-destination": {
            "Address": "https://localhost:7232"
          }
        }
      }

    }
  },

  "Jwt": {
    "Key": "9Kx3Qm7Rw1Tz5Yb8Nc2Vf6Hs0Jd4Lp9Wg2Xm5Zt8",
    "Issuer": "groovra.local",
    "Audience": "groovra.clients"
  }
}