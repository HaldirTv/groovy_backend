{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-users-search-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/users/search", "Methods": [ "GET" ] },
        "Order": -2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "auth-users-admin-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/users/{**catch-all}" },
        "Order": -1,
        "AuthorizationPolicy": "AdminOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/{**catch-all}" },
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "profile-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/profile/{**catch-all}" },
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "artist-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/artist/{**catch-all}" },
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "media-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/media/{**catch-all}" },
        "Order": 0,
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-static-files": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/files/{**catch-all}" },
        "Order": 0,
        "RateLimiterPolicy": "IpBasedLimiter"
      },
      "music-jamendo": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/jamendo/{**catch-all}" },
        "Order": 1,
        "AuthorizationPolicy": "AdminOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },


      "music-tracks-play-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/{id}/play",
          "Methods": [ "POST" ]
        },
        "Order": 1,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-tracks-comments-write": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/{trackId}/comments",
          "Methods": [ "POST" ]
        },
        "Order": 1,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-tracks-comments-actions": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/comments/{**catch-all}",
          "Methods": [ "POST", "DELETE" ]
        },
        "Order": 1,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-tracks-modify": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "Order": 2,
        "AuthorizationPolicy": "ArtistOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-tracks-public-get": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Order": 2,
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-artists-public-get": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/artists/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Order": 2,
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-stats-global-route": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/stats/global" },
        "Order": 1,
        "RateLimiterPolicy": "IpBasedLimiter"
      },


      "music-albums-modify": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/albums/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "Order": 2,
        "AuthorizationPolicy": "ArtistOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-albums-public-get": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/albums/{**catch-all}",
          "Methods": [ "GET" ]
        },
        "Order": 2,
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-upload-modify": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/Upload/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        },
        "Order": 2,
        "AuthorizationPolicy": "ArtistOnly",
        "RateLimiterPolicy": "IpBasedLimiter"
      },


      "music-favorites-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/favorites/{**catch-all}"
        },
        "Order": 2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },


      "music-ai-mixes-public-get": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/playlists/ai-mixes",
          "Methods": [ "GET" ]
        },
        "Order": 1,
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-playlists-search-public-get": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/playlists/search",
          "Methods": [ "GET" ]
        },
        "Order": 1,
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "music-playlists-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/playlists/{**catch-all}"
        },
        "Order": 2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "history-route": {
        "ClusterId": "history-cluster",
        "Match": { "Path": "/api/history/{**catch-all}" },
        "Order": 2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "media-upload-route": {
        "ClusterId": "chat-cluster",
        "Match": { "Path": "/api/media/{**catch-all}" },
        "Order": 1,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "chat-hub-route": {
        "ClusterId": "chat-cluster",
        "Match": { "Path": "/chat/hub/{**catch-all}" },
        "Order": 1,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "chat-route": {
        "ClusterId": "chat-cluster",
        "Match": { "Path": "/chat/{**catch-all}" },
        "Order": 2,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },


      "music-route": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/music/{**catch-all}" },
        "Order": 3,
        "AuthorizationPolicy": "Default",
        "RateLimiterPolicy": "IpBasedLimiter"
      },

      "auth-openapi-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/docs/auth/openapi.json" },
        "Transforms": [ { "PathPattern": "/openapi/v1.json" } ]
      },
      "music-openapi-route": {
        "ClusterId": "music-cluster",
        "Match": { "Path": "/docs/music/openapi.json" },
        "Transforms": [ { "PathPattern": "/openapi/v1.json" } ]
      },
      "history-openapi-route": {
        "ClusterId": "history-cluster",
        "Match": { "Path": "/docs/history/openapi.json" },
        "Transforms": [ { "PathPattern": "/openapi/v1.json" } ]
      },
      "chat-openapi-route": {
        "ClusterId": "chat-cluster",
        "Match": { "Path": "/docs/chat/openapi.json" },
        "Transforms": [ { "PathPattern": "/openapi/v1.json" } ]
      }
    },

    "Clusters": {
      "auth-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "auth-destination": {

            "Address": "https://localhost:7008"
          }
        }
      },
      "music-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "music-destination": {
            "Address": "https://localhost:7176"
          }
        }
      },
      "history-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "Destinations": {
          "history-destination": {
            "Address": "https://localhost:7232"
          }
        }
      },
      "chat-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "Destinations": {
          "chat-destination": {
            "Address": "https://localhost:7288"
          }
        }
      }

    }
  },

  "Jwt": {
    "Key": "",
    "Issuer": "groovra.local",
    "Audience": "groovra.clients"
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5178",
      "https://groovra-frontend-9wtp.vercel.app"
    ]
  }
}
