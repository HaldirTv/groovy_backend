{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      
      "music-get-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/tracks/{**catch-all}",
          "Methods": [ "GET", "HEAD" ] 
        },
        "Order": 1
      },


      "music-modify-route": {
        "ClusterId": "music-cluster",
        "Order": 1,
        "Match": {
          "Path": "/music/{**catch-all}",
          "Methods": [ "POST", "PUT", "PATCH", "DELETE" ]
        }
      },

      "music-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/music/{**catch-all}"
        },
        "Order": 2
      },
      
      
      
      "auth-openapi-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/docs/auth/openapi.json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      },
      "music-openapi-route": {
        "ClusterId": "music-cluster",
        "Match": {
          "Path": "/docs/music/openapi.json"
        },
        "Transforms": [
          { "PathPattern": "/openapi/v1.json" }
        ]
      }


    },
    "Clusters": {
      "auth-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "auth-destination": {

            "Address": "https://localhost:7008"
          }
        }
      },
      "music-cluster": {
        "HttpClient": {
          "DangerousAcceptAnyServerCertificate": true
        },
        "Destinations": {
          "music-destination": {
            "Address": "https://localhost:7176"
          }
        }
      }

    }
  },

  "Jwt": {
    "Key": "super_secret_groovra_jwt_signing_key_32_chars_long",
    "Issuer": "groovra.local",
    "Audience": "groovra.clients"
  }
}