<?xml version="1.0" encoding="utf-8"?>
<!--
  RunSettings для dotnet test.
  Перенаправляет DOTNET_ROOT на ~/.dotnet где установлен Microsoft.AspNetCore.App 10.0.8
  (установлен через dotnet-install.sh без системных прав, т.к. на Arch Linux
  пакет aspnet-runtime-bin ещё не установлен в /usr/share/dotnet/shared).
-->
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <DOTNET_ROOT>/home/shadow/.dotnet</DOTNET_ROOT>
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
