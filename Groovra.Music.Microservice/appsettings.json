{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Та же строка подключения, что и у других сервисов (GroovraDB).
    // Music-сервис использует схему [music] внутри этой БД.
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;AttachDbFilename=D:\\SqlData\\GroovraDB.mdf;Database=GroovraDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "MediaStorage": {
    // Абсолютный путь к папке с медиафайлами.
    // Если пусто — используется <exe-dir>/MediaStorage
    "BasePath": ""
  }
}
