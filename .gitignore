# ==========================================
# 1. .NET / C# (Backend)
# ==========================================
# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleasePublic/
x64/
x86/
build/
bld/
[Bb]in/
[Ob]ject/
[Oo]bj/

# Специфические файлы JetBrains Rider / VS Code
.idea/
*.sln.iml
.vscode/
!.vscode/extensions.json

# User-specific files (Настройки окон, юзеров и локальные конфиги)
*.rsuser
*.suo
*.user
*.useruser
*.sqluser
*.userosscache
*.sln.docstates

# Локальные секреты и appsettings, которые нельзя пушить в гит
# (Особенно важно для паролей от Azure и локальных БД!)
appsettings.Development.json
appsettings.Local.json
_usersecrets_*.json
secrets.json

# ==========================================
# 2. Node.js / React / React Native (Frontend)
# ==========================================
# Зависимости (Самая тяжелая папка, ее никогда не пушим)
node_modules/
jspm_packages/

# Результаты сборки фронта
dist/
tmp/
out/
.next/
.nuxt/

# Локальные переменные окружения фронтенда (токены, ключи API)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.js

# Специфические логи npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Expo (если Микита будет использовать Expo для React Native)
.expo/
*.jks
*.p8
*.keystore

# ==========================================
# 3. Docker & Инфраструктура
# ==========================================
.docker/
# Если будете хранить данные базы прямо в папке проекта через volumes:
docker-data/
postgres-data/
ms-sql-data/

